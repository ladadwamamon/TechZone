# =========================================================
# Copy to deploy/.env and fill in real values.
#   cp deploy/.env.example deploy/.env
# NEVER commit deploy/.env to git.
# =========================================================

# --- PostgreSQL ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=nexus

# --- API server ---
# Secret used to sign session cookies. Generate a strong random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_64_hex_chars
LOG_LEVEL=info

# --- Web (Nginx) ---
# Host port that your edge proxy / Cloudflare points to.
WEB_PORT=8088
